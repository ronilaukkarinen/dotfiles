{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/codestats-hook.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "sunsama_complete_task|mcp__sunsama__sunsama_complete_task|mcp__linear__save_issue|mcp__plugin_linear_linear__save_issue",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/append-changelog.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/update-cross-channel-context.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
